{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$CLAUDE_PROJECT_DIR/.claude/hooks/task-lifecycle.md\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: follow the mandatory task lifecycle in .skills/self_improvement/SKILL.md (pre-work reads, post-work retrospective).'"
          }
        ]
      }
    ]
  }
}
